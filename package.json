{
    "name": "comfyui-connect-the-dots",
    "version": "1.1.0",
    "description": "ComfyUI extension. No more stupid scrolling across the entire graph and then scrolling back just to connect a VAE node.",
    "main": "build/connectTheDots.js",
    "type": "module",
    "author": "Juan Treminio <jtreminio@gmail.com>",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/jtreminio/ComfyUI-ConnectTheDots"
    },
    "scripts": {
        "build": "npm run check && node ./scripts/build.mjs",
        "check": "npm run format:check && npm run lint && npm run typecheck",
        "format": "biome format --write .",
        "format:check": "biome format .",
        "lint": "biome lint .",
        "lint:fix": "biome lint --write .",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "typecheck": "tsc --noEmit"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.11",
        "@vitest/coverage-v8": "^3.2.3",
        "esbuild": "^0.28.0",
        "html-template-tag": "^5.0.0",
        "jsdom": "^26.1.0",
        "typescript": "^6.0.2",
        "vitest": "^3.2.3"
    }
}
